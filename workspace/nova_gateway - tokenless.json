{
  "inference": {
    "context_window": 32768,
    "max_tokens": 16384,
    "timeout_s": 120
  },
  "autonomy": {
    "enabled": true,
    "sleep_interval_s": 300,
    "poll_s": 3,
    "observe_dwell_ticks": 2,
    "min_engage_summary": true,
    "engage_gap_s": 8,
    "watch_paths": [
      "Tasking/Master_Inbox",
      "memory/interrupt_inbox.json",
      "memory/cole_intent.json"
    ]
  },
  "gateway": {
    "port": 18790,
    "host": "127.0.0.1",
    "token": "nova-gateway-local"
  },
  "discord": {
    "enabled": true,
    "token": "[place token here]",
    "allowlist": [],
    "dm_enabled": true,
    "allow_bots": true
  },
  "cron": {
    "health_check": {
      "enabled": false,
      "interval_min": 30,
      "message": "Run Thoughts cycle: read priority.md, process Master_Inbox, advance highest-priority active thought by one step. Then update priority.md if anything changed."
    }
  },
  "context": {
    "inject_files": [
      "BOOTUP/AGENTS.md",
      "BOOTUP/NOVA.md",
      "BOOTUP/TOOLS.md",
      "BOOTUP/NCL_MASTER.md",
      "BOOTUP/UPGRADE_PROTOCOL.md",
      "memory/STATUS.md",
      "memory/COLE.md",
      "Tasking/priority.md",
      "Tasking/THOUGHT_TEMPLATE.md"
    ],
    "heartbeat_extra_files": [
      "BOOTUP/HEARTBEAT.md"
    ]
  },
  "sessions": {
    "dir": "logs/gateway_sessions",
    "compact_at_frac": 0.85,
    "compact_keep_pairs": 10
  },
  "tools": {
    "exec_timeout_s": 60,
    "exec_cwd": null,
    "read_max_bytes": 524288
  }
}
